{
  "name": "agent-nexus",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.10"
  },
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "corepack pnpm --filter @agent-nexus/cli dev",
    "build": "tsc --build && corepack pnpm --filter @agent-nexus/cli bundle",
    "pack:cli": "corepack pnpm --dir packages/cli pack",
    "typecheck": "tsc --build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
