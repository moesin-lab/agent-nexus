#!/usr/bin/env bash
# pretool-read-guard — 通用 PreToolUse 守卫
#
# 作为任何支持 PreToolUse hook 的 agent harness（Claude Code / Codex
# 等）的守卫脚本：拦截对项目文档的 Read 调用，让 agent 改走 docs-read。
#
# 匹配规则（被拦截）：
#     docs/**/*.md
#     AGENTS.md / CLAUDE.md / README.md / CONTRIBUTING.md
#
# 例外（放行）：
#     CHANGELOG.md
#     非 markdown 文件
#     非 Read 工具
#
# 返回：
#     exit 0 → 放行
#     exit 2 → 阻止并把 stderr 回给 agent
#
# 集成（Claude Code 示例，用户自行拷到本地 .claude/settings.json）：
#     {
#       "hooks": {
#         "PreToolUse": [{
#           "matcher": "Read",
#           "hooks": [{ "type": "command",
#                       "command": "scripts/pretool-read-guard" }]
#         }]
#       }
#     }
#
# 其他 harness 按自身文档配置即可。
#
# 配套：AGENTS.md §"读文档的防污染规则"

set -euo pipefail

input=$(cat)

tool_name=$(printf '%s' "$input" | jq -r '.tool_name // ""')
file_path=$(printf '%s' "$input" | jq -r '.tool_input.file_path // ""')
cwd=$(printf '%s' "$input" | jq -r '.cwd // ""')

# 非 Read 工具，直接放行
[[ "$tool_name" == "Read" ]] || exit 0

# 缺 file_path 参数，放行（让 Read 自行报错，避免 hook 误伤）
[[ -n "$file_path" ]] || exit 0

# 转为相对仓库根的路径
rel_path="$file_path"
if [[ -n "$cwd" && "$file_path" == "$cwd"/* ]]; then
    rel_path="${file_path#$cwd/}"
fi

is_blocked() {
    local p="$1"
    # 只管 .md
    [[ "$p" == *.md ]] || return 1
    # CHANGELOG 例外（Keep a Changelog 规范不带 frontmatter）
    [[ "$p" == "CHANGELOG.md" ]] && return 1
    # docs/ 下一律拦
    [[ "$p" == docs/* ]] && return 0
    # 仓库根的规则文档（CLAUDE.md 是 AGENTS.md 的符号链接，也拦）
    case "$p" in
        AGENTS.md|CLAUDE.md|README.md|CONTRIBUTING.md) return 0 ;;
    esac
    return 1
}

if is_blocked "$rel_path"; then
    cat >&2 <<EOF
[pretool-read-guard] 已阻止直接 Read 项目文档：$rel_path

项目约定：读 docs/ 下的 markdown 与仓库根规则文档必须通过 scripts/docs-read。
根据意图选一种模式：

    Bash: scripts/docs-read $rel_path
        默认（智能）：active 返回全文；Superseded / Deprecated / placeholder
        只返回 frontmatter + 告警。**大多数场景走这个。**

    Bash: scripts/docs-read --head $rel_path
        泛读：仅返回 frontmatter，无视状态。想先看 summary / tags 判断
        这篇要不要继续读时用这个。

    Bash: scripts/docs-read --force $rel_path
        强读：强制返回全文；过时状态会在 stderr 告警但仍给正文。仅在
        研究历史（例：复盘被 Superseded 的 ADR 演进）时用。

理由：Read 会把整份文件读进上下文，不会因为 YAML frontmatter 的 --- 停下；
过时文档正文污染上下文后，纠偏代价远高于一开始就过滤。scripts/docs-read
先解析 frontmatter 再决定返回内容，三种模式覆盖三种合法意图。

详见 AGENTS.md §"读文档的防污染规则"。
EOF
    exit 2
fi

exit 0
