#!/usr/bin/env bash
# pretool-read-guard — 通用 PreToolUse 守卫
#
# 作为任何支持 PreToolUse hook 的 agent harness（Claude Code / Codex
# 等）的守卫脚本：拦截对「非权威源」markdown 的 Read 调用。
#
# 设计前提（见 docs/dev/process/docs-read.md）：
#     active 权威文档（AGENTS.md / docs/** 下规则与 spec）放在默认路径，
#     Read 无障碍；
#     两类"非权威源"会让 agent 把非事实内容当事实用，必须拦：
#       1. 归档文档（Superseded / Deprecated / placeholder 的历史内容）
#       2. 面向外部的文档（README.md / CONTRIBUTING.md — 产品介绍与贡献
#          指南的语气；内部 agent 应读 AGENTS.md 或 docs/dev/**，而不是
#          从这些文档推断架构/契约）
#     想读这些内容必须显式走 scripts/docs-read --force（或经 hook 指引）。
#
# 被拦截的路径：
#     docs/dev/adr/deprecated/**/*.md
#     docs/_deprecated/**/*.md
#     README.md / CONTRIBUTING.md（仓库根的外部导向文档）
#
# 放行（不管是不是 markdown）：
#     AGENTS.md / CLAUDE.md / CHANGELOG.md（内部权威规则 + 变更日志）
#     active 的 docs/**/*.md
#     非 markdown 文件
#     非 Read 工具
#
# 返回：
#     exit 0 → 放行
#     exit 2 → 阻止并把 stderr 回给 agent
#
# 集成（Claude Code 示例，用户自行拷到本地 .claude/settings.json）：
#     {
#       "hooks": {
#         "PreToolUse": [{
#           "matcher": "Read",
#           "hooks": [{ "type": "command",
#                       "command": "scripts/pretool-read-guard" }]
#         }]
#       }
#     }
#
# 其他 harness 按自身文档配置即可。

set -euo pipefail

input=$(cat)

tool_name=$(printf '%s' "$input" | jq -r '.tool_name // ""')
file_path=$(printf '%s' "$input" | jq -r '.tool_input.file_path // ""')
cwd=$(printf '%s' "$input" | jq -r '.cwd // ""')

# 非 Read 工具，直接放行
[[ "$tool_name" == "Read" ]] || exit 0

# 缺 file_path 参数，放行（让 Read 自行报错，避免 hook 误伤）
[[ -n "$file_path" ]] || exit 0

# 转为相对仓库根的路径
rel_path="$file_path"
if [[ -n "$cwd" && "$file_path" == "$cwd"/* ]]; then
    rel_path="${file_path#$cwd/}"
fi

# 返回拦截类别：archived / external / ""（不拦）
block_kind() {
    local p="$1"
    [[ "$p" == *.md ]] || { echo ""; return; }
    if [[ "$p" == docs/dev/adr/deprecated/* ]] || [[ "$p" == docs/_deprecated/* ]]; then
        echo "archived"
    elif [[ "$p" == "README.md" ]] || [[ "$p" == "CONTRIBUTING.md" ]]; then
        echo "external"
    else
        echo ""
    fi
}

kind=$(block_kind "$rel_path")

case "$kind" in
    archived)
        cat >&2 <<EOF
[pretool-read-guard] 已阻止直接 Read 归档文档：$rel_path

这份文档位于归档目录，意味着它已被取代 / 废弃 / 仅为占位符。
路径本身就是"别当事实来源"的信号 —— 读它的全文有污染当前决策的风险。

如果你确实要研究历史演进（例：复盘某条 Superseded ADR 的推导轨迹），用：

    Bash: scripts/docs-read --force $rel_path

该入口会在 stderr 明确告警，提醒你所读内容不代表当前权威决策。

详见 docs/dev/process/docs-read.md。
EOF
        exit 2
        ;;
    external)
        cat >&2 <<EOF
[pretool-read-guard] 已阻止直接 Read 面向外部的文档：$rel_path

README.md / CONTRIBUTING.md 是面向外部访客与贡献者的文档（产品介绍、
贡献指南），不是内部决策的事实源。常规开发任务应读 AGENTS.md（协作
规则）、docs/dev/**（架构/spec/ADR）或代码本身，而不是从这些文档
推断架构/契约。

如果你确实要读（例：帮用户改文案、核对外部描述是否与内部 spec 一致），用：

    Bash: scripts/docs-read --force $rel_path

详见 docs/dev/process/docs-read.md。
EOF
        exit 2
        ;;
esac

exit 0
