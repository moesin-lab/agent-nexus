#!/usr/bin/env bash
# docs-read — 项目文档阅读辅助（预览 / 归档强读 / frontmatter 漂移兜底）
#
# 本脚本与 pretool-read-guard 协同：
#     agent 对 active 路径下文档的 Read，由 hook 放行 → 直接 Read 即可；
#     归档路径（docs/dev/adr/deprecated/** / docs/_deprecated/**）的 Read 被 hook
#     拦截，需显式走本脚本的 --force 模式（是唯一合法的"我知道我要读归档"入口）。
#
# 本脚本还承担一层兜底：若 active 路径下的文档 frontmatter 被标注为 placeholder
# / deprecated / Superseded（即"状态漂移"，未 git mv 到归档目录），默认模式会
# 在返回前降级到只给 frontmatter + 告警，提示 reviewer 把它迁移到归档目录。
#
# 三种模式：
#
#     docs-read <path>              默认（智能）：active 返回全文；frontmatter
#                                   指向过时状态则降级为 frontmatter + 告警
#                                   （提示"考虑移到归档目录"）。
#
#     docs-read --head <path>       泛读：仅返回 frontmatter，无视文档状态。
#                                   用于先判断一篇文档值不值得读全文。
#
#     docs-read --force <path>      强读：强制返回全文；两类情况 stderr 告警
#                                   但仍返回全文——①路径是外部导向文档
#                                   （README.md / CONTRIBUTING.md）；②frontmatter
#                                   标记为过时（deprecated / placeholder /
#                                   Superseded）。归档目录中的文档 + 外部导向
#                                   文档必须经此入口读取（由 pretool-read-guard
#                                   指引）。
#
# 退出码：
#     0   正常返回
#     2   默认模式下文档状态过时，仅返回 frontmatter + 告警
#     1   用法错误或文件不存在
#
# 依赖：bash + awk（POSIX 功能集），无外部工具依赖
#
# See: docs/dev/standards/metadata.md
#      AGENTS.md §"读文档的防污染规则"
#      scripts/pretool-read-guard

set -euo pipefail

mode="auto"
path=""

usage() {
    cat <<'EOF'
Usage:
    docs-read <path>              默认（智能）：active 全文；过时 frontmatter + 告警
    docs-read --head <path>       泛读：仅 frontmatter（无视状态）
    docs-read --force <path>      强读：强制全文（过时会 stderr 告警）
    docs-read -h | --help         打印本帮助

Exit codes:
    0   正常返回
    2   默认模式下文档过时，仅返回 frontmatter
    1   用法错误 / 文件不存在
EOF
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        --head)
            mode="head"
            shift
            ;;
        --force)
            mode="force"
            shift
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        --)
            shift
            if [[ $# -eq 1 ]]; then path="$1"; shift; else
                echo "ERROR: expected exactly one path after --" >&2
                exit 1
            fi
            ;;
        -*)
            echo "ERROR: unknown option: $1" >&2
            usage >&2
            exit 1
            ;;
        *)
            if [[ -z "$path" ]]; then
                path="$1"
            else
                echo "ERROR: multiple paths given" >&2
                exit 1
            fi
            shift
            ;;
    esac
done

if [[ -z "$path" ]]; then
    usage >&2
    exit 1
fi

if [[ ! -f "$path" ]]; then
    echo "ERROR: file not found: $path" >&2
    exit 1
fi

# 提取 frontmatter（第一对 --- 之间的内容）
frontmatter=$(awk '
    BEGIN { inside = 0; count = 0 }
    /^---$/ {
        count++
        if (count == 1) { inside = 1; next }
        if (count == 2) { exit }
    }
    inside == 1 { print }
' "$path")

# 从 frontmatter 提取字段值（简陋 YAML 标量解析，不处理列表/嵌套）
get_field() {
    local key="$1"
    echo "$frontmatter" | awk -v k="^${key}:" '
        $0 ~ k {
            sub(/^[^:]+:[ \t]*/, "")
            sub(/#.*/, "")
            gsub(/^[ \t"]+|[ \t"]+$/, "")
            print
            exit
        }
    '
}

# ----- head 模式：仅返回 frontmatter -----
if [[ "$mode" == "head" ]]; then
    if [[ -z "$frontmatter" ]]; then
        echo "WARN: no YAML frontmatter found in $path" >&2
        exit 0
    fi
    echo "---"
    echo "$frontmatter"
    echo "---"
    exit 0
fi

# ----- force 模式：强制返回全文，两类场景发 stderr 告警 -----
# 场景 A：外部导向文档（README.md / CONTRIBUTING.md 在仓库根）
# 场景 B：frontmatter 标记为过时（deprecated / placeholder / Superseded / Deprecated）
if [[ "$mode" == "force" ]]; then
    # 场景 A：外部导向判定——不含 / 的直接文件名，且是 README/CONTRIBUTING
    if [[ "$path" != */* && ( "$path" == "README.md" || "$path" == "CONTRIBUTING.md" ) ]]; then
        echo "[docs-read --force] 注意：按 --force 读取外部导向文档全文" >&2
        echo "   path:  $path" >&2
        echo "   这份文档面向仓库外部读者（产品介绍 / 贡献指南），不是内部决策的事实源。" >&2
        echo "   常规开发任务应以 AGENTS.md 与 docs/dev/** 为准。" >&2
    # 场景 B：frontmatter 过时判定
    elif [[ -n "$frontmatter" ]]; then
        status=$(get_field "status")
        adr_status=$(get_field "adr_status")
        title=$(get_field "title")
        declare -a warns=()
        case "$status" in
            deprecated|placeholder)
                warns+=("status=$status")
                ;;
        esac
        case "$adr_status" in
            Superseded|Deprecated)
                warns+=("adr_status=$adr_status")
                ;;
        esac
        if [[ ${#warns[@]} -gt 0 ]]; then
            echo "[docs-read --force] 注意：按 --force 读取过时文档全文" >&2
            echo "   path:  $path" >&2
            [[ -n "${title:-}" ]] && echo "   title: $title" >&2
            for w in "${warns[@]}"; do
                echo "   flag:  $w" >&2
            done
        fi
    fi
    cat "$path"
    exit 0
fi

# ----- 默认（auto）模式 -----

if [[ -z "$frontmatter" ]]; then
    echo "WARN: no YAML frontmatter found; returning full file" >&2
    cat "$path"
    exit 0
fi

title=$(get_field "title")
status=$(get_field "status")
adr_status=$(get_field "adr_status")
superseded_by=$(get_field "superseded_by")

should_stop=0
declare -a reasons=()

case "$status" in
    deprecated)
        should_stop=1
        reasons+=("status=deprecated：此文档已废弃，不作依据")
        ;;
    placeholder)
        should_stop=1
        reasons+=("status=placeholder：仅占位，内容是骨架，不作权威依据")
        ;;
esac

case "$adr_status" in
    Superseded)
        should_stop=1
        if [[ -n "${superseded_by:-}" && "${superseded_by}" != "null" ]]; then
            reasons+=("adr_status=Superseded by ${superseded_by}：请改读取代者 ADR-${superseded_by}")
        else
            reasons+=("adr_status=Superseded：该决策已被取代")
        fi
        ;;
    Deprecated)
        should_stop=1
        reasons+=("adr_status=Deprecated：决策已失效")
        ;;
esac

if [[ $should_stop -eq 1 ]]; then
    echo "==================================================================="
    echo "!! STOPPED by docs-read (default mode) — frontmatter 状态漂移"
    echo "   path:   $path"
    [[ -n "${title:-}" ]] && echo "   title:  $title"
    for r in "${reasons[@]}"; do
        echo "   reason: $r"
    done
    echo ""
    echo "这份文档位于 active 路径但被标记为过时状态 —— 这是"状态漂移"，"
    echo "规范做法是把它 git mv 到归档目录（docs/dev/adr/deprecated/ 或"
    echo "docs/_deprecated/），由 pretool-read-guard 按路径拦截。"
    echo ""
    echo "如果此刻确需全文：docs-read --force $path"
    echo "如果仅需 frontmatter：docs-read --head $path"
    echo ""
    echo "以下仅为 frontmatter（未返回正文，避免上下文污染）："
    echo "==================================================================="
    echo "---"
    echo "$frontmatter"
    echo "---"
    exit 2
fi

# active 文档 → 返回全文
cat "$path"
